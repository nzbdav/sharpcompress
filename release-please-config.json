{
  "packages": {
    ".": {
      "release-type": "simple",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "regex",
          "path": "src/SharpCompress/SharpCompress.csproj",
          "find": "<Version>.*?</Version>",
          "replace": "<Version>${version}</Version>"
        }
      ]
    }
  }
}
